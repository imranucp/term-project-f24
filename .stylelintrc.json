{ 
  "rules":{
    "color-no-invalid-hex": true,
    "block-no-empty": true,
    "indentation": 2,
    "string-quotes": "single",
    "selector-max-id": 0,
    "max-nesting-depth": 3,
    "no-extra-semicolons": true,
    "selector-max-class": 3,
    "color-named": "never",
    "property-no-unknown": true
  }
}