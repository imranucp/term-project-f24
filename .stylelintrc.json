{
  "rules": {
    "color-no-invalid-hex": true,
    "declaration-colon-space-after": "always",
    "block-no-empty": true,
    "unit-whitelist": ["em", "rem", "%", "s", "px"],
    "indentation": 2,
    "number-leading-zero": "always",
    "string-quotes": "double",
    "selector-max-id": 1,
    "selector-max-universal": 1,
    "property-no-vendor-prefix": true
  }
}
